# Protiv CS Dashboard — Environment Variables
# Set these in Render's dashboard under Environment > Environment Variables

# Metabase connection
METABASE_URL=https://metabase.protiv.com
METABASE_API_KEY=your_metabase_api_key_here
CARD_CS_BILLING=71
CARD_BONUSES_PAID=74
CARD_MISSING_INVITES=73

# Dashboard password (shared with your CS/Sales team)
DASHBOARD_PASSWORD=your_team_password_here

# Session secret (any random string)
SESSION_SECRET=change-this-to-a-random-string

# Render sets PORT automatically, no need to set it
# TRUST_PROXY=true (set this in production)
